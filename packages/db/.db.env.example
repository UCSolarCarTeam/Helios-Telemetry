# Local database environment variables
# Copy this file to .db.env and replace with your actual values
# Docker Compose uses these values directly.
# Local db package scripts can also fall back to this file.

# PostgreSQL User (default: postgres)
POSTGRES_USER=postgres

# PostgreSQL Password (REQUIRED - change this!)
# This should match DATABASE_PASSWORD in packages/server/.env
POSTGRES_PASSWORD=your_secure_password_here

# Database Name (default: tsdb)
# Note: The application expects this to be 'tsdb' - do not change unless you know what you're doing
POSTGRES_DB=tsdb
