# Copy to `packages/db/.env` and set real values. Do not commit secrets.
# This file is loaded by Docker Compose (local Postgres) and by Prisma via `src/data-source.ts`.

########################
# Local Postgres (Docker Compose)
########################
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpasswordlocalhost
POSTGRES_DB=postgres

########################
# Prisma (CLI, db:studio, app runtime)
########################
DATABASE_URL=postgresql://postgres:yourpasswordlocalhost@localhost:5432/postgres
DIRECT_URL=postgresql://postgres:yourpasswordlocalhost@localhost:5432/postgres