{
  "name": "db",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "jest --runInBand",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f db",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "yarn db:down && yarn db:up && sleep 10 && yarn db:seed",
    "migrate:dev": "prisma migrate dev",
    "migrate:run": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:reset:force": "prisma migrate reset --force --skip-seed",
    "db:generate": "prisma generate",
    "db:pull": "prisma db pull",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.17.0",
    "@shared/helios-types": "workspace:*",
    "dotenv": "^16.4.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "prisma": "^6.17.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.3"
  }
}
