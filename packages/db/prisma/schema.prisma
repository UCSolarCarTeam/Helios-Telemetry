generator client {
  provider = "prisma-client-js"
  // Hoisted workspace installs resolve @prisma/client from the repo root; the default output
  // (under packages/db) would leave the root stub in place. Path is relative to this folder.
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model driver {
  rfid      String   @id(map: "PK_5ec5aa7279436b862c308d63f5b")
  Name      String
  CreatedAt DateTime @default(now()) @db.Timestamptz(6)
  UpdatedAt DateTime @updatedAt @db.Timestamptz(6)
}

model lap {
  Id                      String   @id(map: "PK_bde83ce36fb9632ffd544022604") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp               DateTime @db.Timestamptz(6)
  rfid                    String
  LapTime                 Float
  TotalPowerIn            Float
  TotalPowerOut           Float
  NetPowerOut             Float
  Distance                Float
  EnergyConsumed          Float
  AmpHours                Float
  AveragePackCurrent      Float
  BatterySecondsRemaining Float
  AverageSpeed            Float
  AverageMotorWattage     Float

  @@index([rfid, timestamp], map: "IDX_847b73ee1f3faf017fe4e9a6cb")
}

model grafana_snapshot {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url        String   @unique
  label      String
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

