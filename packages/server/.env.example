# Copy to `packages/server/.env` and set real values. Do not commit secrets.
#
# Reference: `process.env` usage under packages/server/src (database via db package
# is configured in packages/db/.env; Prisma also reads DATABASE_URL / DIRECT_URL from there
# on import, so keep the two in sync for local work).

########################
# Core
########################
NODE_ENV=development

# Prisma
DATABASE_URL=postgresql://postgres:yourpasswordlocalhost@localhost:5432/postgres
DIRECT_URL=postgresql://postgres:yourpasswordlocalhost@localhost:5432/postgres

########################
# MQTT
########################
MQTT_USERNAME=primaryuser
MQTT_PASSWORD=changeme

########################
# App secrets
########################
DRIVER_NAME_UPDATE_PASSWORD=changeme
FINISH_LINE_UPDATE_PASSWORD=changeme

########################
# Machine Learning
########################
PACKET_CORRELATION_MATRIX_FUNCTION_NAME=changeme
LAP_CORRELATION_MATRIX_FUNCTION_NAME=changeme
